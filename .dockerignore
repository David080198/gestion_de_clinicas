# ============================================================
# .dockerignore - Reduce el contexto de build de Docker
# Excluye archivos innecesarios para imagenes mas pequenas y rapidas
# ============================================================

# Entorno y secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Alembic migrations deben viajar en la imagen Docker
# NO ignorar archivos de migración

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Git
.git/
.gitignore

# Documentacion
docs/
*.md
!DEPLOY.md

# Scripts de verificacion local
verify_*.py

# CI/CD
.github/
.gitlab-ci.yml
