# ============================================================
# Variables de entorno - Medical Clinic (Dokploy)
# ============================================================
# Copia este archivo a .env y completa los valores.
# En Dokploy, estas variables se inyectan automaticamente desde el panel
# de configuracion del servicio (Environment Variables).
# ============================================================

# --- Entorno ---
FLASK_ENV=production
FLASK_APP=run.py
SECRET_KEY=cambia-esta-clave-por-una-cadena-aleatoria-de-64-caracteres

# --- Dominio (para Traefik / Dokploy) ---
# Dokploy inyecta automaticamente el dominio asignado al servicio.
# Si lo defines manualmente, debe coincidir con el dominio configurado en Dokploy.
DOMAIN=medcenter.tudominio.com

# --- Red de Dokploy ---
# Nombre de la red Docker externa que Dokploy usa para Traefik.
# Por defecto Dokploy crea "dokploy-network".
DOKPLOY_NETWORK=dokploy-network

# --- Base de datos PostgreSQL ---
# En docker-compose, el host es "db" (nombre del servicio).
# Dokploy puede inyectar estas variables o usar DATABASE_URL directamente.
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=clinic_password
POSTGRES_DB=clinic_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL se construye automaticamente en docker-entrypoint.sh
# a partir de POSTGRES_* si no esta definida.
DATABASE_URL=postgresql://clinic_user:clinic_password@db:5432/clinic_db

# --- JWT ---
JWT_SECRET_KEY=cambia-esta-clave-jwt-por-una-cadena-aleatoria
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_TOKEN_LOCATION=cookies
# En produccion detras de Traefik (HTTPS), las cookies deben ser seguras
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True
JWT_COOKIE_SAMESITE=Lax

# --- Configuracion de la clinica ---
CLINIC_NAME=MedCenter Premium
CLINIC_TIMEZONE=America/Mexico_City
CLINIC_CURRENCY=MXN

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# --- Puerto interno (no publicar al host, Traefik enruta) ---
APP_PORT=5000

# --- Datos demo (0 = no, 1 = seed inicial para demo) ---
SEED_DEMO_DATA=0

# --- Fallback de base de datos (SOLO desarrollo/primer despliegue) ---
# Si=1 y flask db upgrade falla, crea tablas con db.create_all().
# En produccion debe ser 0 para no perder datos.
ALLOW_INIT_DB_FALLBACK=0

# --- Reset de base de datos (EMERGENCIAS SOLAMENTE) ---
# Si=1, dropea el schema public y recrea desde cero antes de las migraciones.
# ADVERTENCIA: Esto elimina TODOS los datos. Usar solo en emergencias.
# Siempre cambiar a 0 despues del restart.
RESET_DATABASE=0

# --- Stripe ---
# Obtener de https://dashboard.stripe.com/apikeys
# Usa sk_test_... para desarrollo y sk_live_... para produccion.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs de Stripe para cada plan y ciclo.
# Crear productos y precios en: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_...
STRIPE_PRICE_CLINIC_MONTHLY=price_...
STRIPE_PRICE_CLINIC_YEARLY=price_...
